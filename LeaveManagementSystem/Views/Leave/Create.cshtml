
@model LeaveManagementSystem.Models.Employee



@{
    var Employee = ViewData["Employee"] as IEnumerable<SelectListItem>;

}


<h1>Leave Application</h1> 
<hr >
<hr color="red" size="2" width="100%">


<form method="post">
    <h3 color="red">Welcome  @Model.Name </h3>
    <div>
        <label for="startDate">Start Date:</label>
        <input type="date" id="startDate" name="startDate"onchange="calculateTotalDays()" required>
    </div>
    <div>
        <label for="endDate">End Date:</label>
        <input type="date" id="endDate" name="endDate" onchange="calculateTotalDays()" required>
    </div>
    <div>
        <label for="endDate"></label>
       
    </div>
    <div class="form-group">
        <label for="LeaveDescription">leave Description:</label>

        <div id="leaveDescription">
        
                <input type="text" id="leaveDescription" name="leaveDescription" required>
        </div>
    </div>

    
    

    <div>
        <button type="submit">Submit</button>
    </div>
</form>


























@section Scripts {
    <script src="https://appsforoffice.microsoft.com/lib/1/hosted/office.js"></script>
    <script>
        Office.initialize = function () {
            var editor = new OfficeRibbon.Editor(document.getElementById("leaveDescription"), {
                onContentChanged: function (content) {
                    document.getElementById("leaveDescription").value = content;
                }
            });
        };

        function calculateTotalDays() {
            alert("hello");
            const start = document.getElementById('startDate');
            const end = document.getElementById('endDate');

            const timeDifference = Math.abs(end - start);
            const totalDays = Math.ceil(timeDifference / (1000 * 60 * 60 * 24));
            console.log("days",totalDays);
            return totalDays;
        }
    </script>
}
